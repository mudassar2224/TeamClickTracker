# Environment Variables - Copy to .env and fill with your values

# Firebase Configuration
FIREBASE_API_KEY=YOUR_API_KEY_HERE
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
FIREBASE_APP_ID=your-app-id
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Environment
NODE_ENV=development
VITE_MODE=development

# Optional: Firebase Emulator (local development)
USE_FIREBASE_EMULATOR=false
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# Optional: Analytics
ENABLE_ANALYTICS=false
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# GA4 Data API (REAL earnings from Google Analytics)
# Numeric GA4 property ID (not the Measurement ID like G-XXXX)
GA4_PROPERTY_ID=YOUR_GA4_PROPERTY_ID
GA_LOOKBACK_DAYS=30
MEMBER_COMMISSION_RATE=0.70
ADMIN_COMMISSION_RATE=0.30
# Optional: run GA sync once on backend startup (helpful for verification)
GA_FETCH_ON_STARTUP=false
# Local dev only: service account JSON key file path (must have Analytics "Viewer" access to the GA4 property)
GOOGLE_ANALYTICS_KEY_FILE=./config/google-analytics-key.json

# Hosted/serverless (Vercel, etc): provide credentials via environment variables instead of a JSON file.
# Paste the ENTIRE service-account JSON as a single line.
FIREBASE_SERVICE_ACCOUNT=

# Optional: separate credentials for GA Data API (if omitted, FIREBASE_SERVICE_ACCOUNT is used)
GOOGLE_ANALYTICS_SERVICE_ACCOUNT=

# Optional: protect internal endpoints like:
# - POST /api/jobs/test/:jobName
# - POST /api/populate-sample-data
# Use header: x-internal-api-key: <value>
# Or query: ?internalApiKey=<value>  (less secure; supported for cron tools)
INTERNAL_API_KEY=

# Optional: disable the node-cron scheduler when running as a long-lived server
DISABLE_SCHEDULER=false

# Optional: Email Notifications
SEND_FRAUD_REPORTS=false
ADMIN_EMAIL=admin@example.com

# Optional: VPN Detection API
VPN_DETECTION_API_KEY=your-api-key
