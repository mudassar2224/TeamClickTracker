rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isMember(memberId) {
      return request.auth != null && request.auth.uid == memberId;
    }

    // Admin collection - only accessible by that admin
    match /admins/{adminId} {
      allow read, write: if isOwner(adminId);
    }

    // Team members collection
    match /team_members/{memberId} {
      allow read: if isAuthenticated() && (isOwner(memberId) || isAdmin());
      allow create: if isAdmin();
      allow update: if isOwner(memberId) || isAdmin();
      allow delete: if isAdmin();
    }

    // UTM links collection
    match /utm_links/{linkId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Clicks collection - public write, restricted read
    match /clicks/{clickId} {
      allow write: if true;  // Public can write clicks
      allow read: if isAuthenticated() && (isAdmin() || 
                                          isOwner(resource.data.team_member_id));
    }

    // Earnings collection
    match /earnings/{earningId} {
      allow read: if isAuthenticated() && (isAdmin() ||
                                          isOwner(resource.data.team_member_id));
      allow write: if isAdmin();
    }

    // User roles collection
    match /user_roles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    // Daily earnings summary
    match /daily_earnings_summary/{summaryId} {
      allow read: if isAuthenticated() && (isAdmin() ||
                                          isOwner(resource.data.member_id));
      allow write: if isAdmin();
    }

    // Fraud reports
    match /fraud_reports/{reportId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
