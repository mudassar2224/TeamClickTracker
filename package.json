{
  "name": "TeamClickTracker",
  "description": "Professional Team Click Tracking & Earnings Dashboard",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "directories": {
    "config": "./config",
    "frontend": "./frontend",
    "backend": "./backend"
  },
  "scripts": {
    "dev": "firebase emulators:start",
    "deploy": "firebase deploy",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "build": "echo 'No build needed for this project'",
    "start": "node backend/index.js",
    "backend": "node backend/index.js",
    "backend:dev": "nodemon backend/index.js"
  },
  "keywords": [
    "firestore",
    "firebase",
    "click-tracking",
    "utm",
    "analytics",
    "fraud-detection",
    "earnings",
    "dashboard"
  ],
  "author": "Your Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0",
    "cors": "^2.8.0",
    "express": "^4.18.0",
    "firebase": "^10.5.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.4.0",
    "googleapis": "^118.0.0",
    "node-cron": "^3.0.0",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "firebase-tools": "^12.9.0"
  }
}
